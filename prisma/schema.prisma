generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  password         String?                   // Hashed password (null if Google-only)
  image            String?
  role             UserRole  @default(CONSULTANT)
  isActive         Boolean   @default(true)
  googleCalId      String?
  googleConnected  Boolean   @default(false)
  // Guest: which channel and workspace they have access to
  assignedChannelId   String?
  assignedChannel     Channel?          @relation("GuestChannel", fields: [assignedChannelId], references: [id])
  assignedDashboardId String?                          // legacy - mantido para compat
  assignedDashboard   ClientDashboard?  @relation(fields: [assignedDashboardId], references: [id])
  assignedWorkspaceClientId String?                    // Guest tem acesso ao workspace deste cliente (dashboard + CRM leads + sales analysis)
  assignedWorkspaceClient   Client?           @relation("GuestWorkspace", fields: [assignedWorkspaceClientId], references: [id])
  // RGPD Consents
  consentPrivacyPolicy    Boolean   @default(false)  // Politica de privacidade (obrigatorio)
  consentTerms            Boolean   @default(false)  // Termos de consentimento (obrigatorio)
  consentDPA              Boolean   @default(false)  // DPA - Data Processing Agreement (obrigatorio)
  consentDataDeletion     Boolean   @default(false)  // Direito ao esquecimento (opcional)
  consentAIAnalysis       Boolean   @default(false)  // Analise de chamadas com IA (opcional)
  consentsAcceptedAt      DateTime?                  // Quando aceitou
  // First-login password change flow
  mustChangePassword Boolean  @default(false)         // Forca troca de password no 1o login
  welcomeEmailSentAt DateTime?                        // Quando foi enviado o email de boas-vindas
  // Sales consultant profile for personalized feedback
  salesProfile     Json?                       // {personality, strengths, weaknesses, style, goals}
  weeklyCallTarget Int       @default(5)       // Weekly call submission target
  sessions         Session[]
  callSubmissions  CallSubmission[]
  feedbacks        Feedback[]
  accounts         Account[]
  channelsCreated    Channel[]         @relation("ChannelCreator")
  subChannelsCreated SubChannel[]      @relation("SubChannelCreator")
  channelMembers     ChannelMember[]
  subChannelMembers  SubChannelMember[]
  messages           Message[]
  scheduledMessages  ScheduledMessage[] @relation("ScheduledMessageAuthor")
  trackerTasks       TrackerTask[]     @relation("TrackerTaskOwner")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Client {
  id               String       @id @default(cuid())
  name             String
  ceo              String?
  email            String?
  phone            String?
  coreBusiness     String?
  composition      String?
  painPoints       String?
  projectDuration  String?
  projectStart     DateTime?
  projectEnd       DateTime?
  status           ClientStatus @default(FECHADO)
  offer            String[]
  risk             Risk?
  csat             Int?
  ticket           Float?
  billing          Float?
  expectations     String?
  otherInfo        String?
  salesConsulting  Boolean      @default(false)
  dashboardReview Boolean      @default(false)
  slackChannelId  String?                  // Canal Slack do cliente
  sessions         Session[]
  documents        Document[]
  recordings       Recording[]
  channels         Channel[]
  timelines        Timeline[]
  referralsGiven   Referral[]   @relation("ReferrerClient")
  dashboard        ClientDashboard?
  leads            Lead[]
  salesAnalyses    SalesAnalysis[]
  guestUsers       User[]       @relation("GuestWorkspace")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Session {
  id               String        @id @default(cuid())
  title            String
  module           String
  topic            String?
  date             DateTime?
  status           SessionStatus @default(POR_AGENDAR)
  evaluation       Int?
  assignedToId     String?
  assignedTo       User?         @relation(fields: [assignedToId], references: [id])
  clientId         String
  client           Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  firefliesId      String?       @unique
  firefliesSummary String?       @db.Text
  firefliesNotes   String?       @db.Text
  actionItems      Json?
  actionPlan       Json?                   // Plano de acao estruturado gerado pela IA
  actionPlanSentAt DateTime?               // Quando foi enviado via Slack
  aiAnalysis       Json?                   // Analise IA completa da reuniao
  aiScore          Int?                    // Score 0-100 da reuniao
  calendarEventId  String?
  notes            String?       @db.Text
  slackChannelId   String?
  firefliesRecordingUrl String?             // Link direto para gravacao no Fireflies
  // Quando uma sessao MARCADA passa a data sem Fireflies a transcrever, o
  // gestor/consultor decide o que aconteceu: REAGENDADA/CANCELADA/sem Fireflies
  missedReason     String?                  // "REAGENDADA" | "CANCELADA" | "FIREFLIES_AUSENTE"
  missedReasonAt   DateTime?                // Quando foi marcado
  missedReasonBy   String?                  // userId que marcou
  recordings       Recording[]
  documents        Document[]
  feedbacks        Feedback[]
  reminders        Reminder[]
  actionPlanDrafts ActionPlanDraft[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Recording {
  id          String        @id @default(cuid())
  title       String
  type        RecordingType @default(CALL)
  duration    Int?
  fileUrl     String
  fileSize    Int?
  transcript  String?       @db.Text
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sessionId   String?
  session     Session?      @relation(fields: [sessionId], references: [id])
  aiAnalysis  Json?
  aiScore     Float?
  scriptName  String?
  analyzedAt  DateTime?
  // AssemblyAI deep audio analysis
  assemblyTranscriptId String?    // ID do transcript AssemblyAI (para correlacao)
  audioAnalysis        Json?      // Resultado completo: sentiment, tom, pausas, wpm, etc.
  audioAnalyzedAt      DateTime?
  callSubmissions CallSubmission[]
  feedbacks       Feedback[]
  salesAnalysis   SalesAnalysis?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Document {
  id             String    @id @default(cuid())
  title          String
  pillar         String
  googleDocsId   String?   @unique
  googleDocsUrl  String?
  lastSyncedAt   DateTime?
  // Documentos locais (contratos gerados, faturas, etc.)
  filePath       String?                             // Path no volume persistente do VPS
  fileMime       String?                             // application/pdf, application/vnd.openxmlformats-officedocument.wordprocessingml.document
  fileSizeBytes  Int?
  source         String?                             // "google" | "ghl-contract" | "invoice-ninja" | "upload"
  externalId     String?                             // ID externo (ex: Invoice Ninja invoice_id)
  externalUrl    String?                             // Link publico (ex: invoice URL)
  clientId       String?
  client         Client?   @relation(fields: [clientId], references: [id])
  sessionId      String?
  session        Session?  @relation(fields: [sessionId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// Tracking de uploads de audio que foram enviados ao Fireflies via API.
// Fireflies nao dispara webhook para esses uploads; o cron poll-fireflies
// verifica regularmente se a transcricao ja esta pronta e dispara o processo.
model PendingFirefliesUpload {
  id              String    @id @default(cuid())
  // Identificacao da chamada
  audioPublicUrl  String                              // URL servida pelo BoomLab
  title           String                              // Titulo enviado ao Fireflies
  // Contexto BoomLab
  clientId        String                              // Cliente onde a analise vai parar
  commercial      String                              // Nome do consultor
  leadName        String?                             // Nome da lead (opcional)
  callType        String                              // Discovery Call, etc
  visibility      String                              // COMMERCIAL_ONLY | WHOLE_TEAM
  // Tracking
  firefliesId     String?                             // Set quando encontramos o transcript
  status          String    @default("PENDING")       // PENDING | PROCESSED | FAILED
  attempts        Int       @default(0)
  lastCheckedAt   DateTime?
  processedAt     DateTime?
  errorMessage    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([status, lastCheckedAt])
}

model AIScript {
  id            String   @id @default(cuid())
  name          String
  pillar        String
  category      String?                       // scripts-vendas, frameworks-reuniao, criterios, materiais, esquemas-sops
  content       String   @db.Text
  criteria      Json?
  isActive      Boolean  @default(true)
  // Market scope - auto-detected by AI when doc is created
  // Array of market codes: "ALL", "CREDITO", "SEGUROS", "IMOBILIARIO"
  // "ALL" means the doc applies to every market
  markets       String[] @default(["ALL"])
  // File / Google Doc attachments
  fileUrl       String?                       // URL de ficheiro uploadado (pdf, docx, etc.)
  fileName      String?                       // Nome original do ficheiro
  fileType      String?                       // mime type
  googleDocUrl  String?                       // Link para Google Doc / Sheet / Slide
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==========================================
// CRM LEADS (per client, per commercial)
// ==========================================

model Lead {
  id              String     @id @default(cuid())
  clientId        String                         // Cliente a que pertence esta lead (a empresa BoomLab)
  client          Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  commercial      String                         // Nome do comercial que tem esta lead (dentro da equipa do cliente)
  // Company info (obrigatorio company e pelo menos 1 contacto empresa)
  company         String                         // Nome da empresa (obrigatorio)
  companyEmail    String?                        // Email geral da empresa
  companyLandline String?                        // Nº fixo da empresa
  companyMobile   String?                        // Nº movel da empresa
  nif             String?                        // NIF / VAT da empresa
  // Decisor (opcional - podem ser varios)
  name            String                         // Nome do decisor (se vazio, copia de company)
  email           String?                        // Email do decisor
  phone           String?                        // Nº do decisor (movel ou fixo)
  // Lead status & pipeline
  status          LeadStatus @default(NOVA)
  source          String?                        // Canal origem: cold-calling, linkedin, anuncios, etc.
  priority        String?                        // alta, media, baixa
  // Contact tracking
  firstContactAt  DateTime?
  lastContactAt   DateTime?
  nextFollowUpAt  DateTime?
  // Qualification
  budget          Float?
  urgency         String?
  painPoints      String?    @db.Text
  // Outcome
  convertedAt     DateTime?
  conversionValue Float?
  lostReason      String?
  // Extra
  notes           String?    @db.Text
  tags            String[]
  // Duplicate detection (set via trigger/service when match found)
  duplicateOfId   String?                        // Se for duplicado, referencia a lead original
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([clientId, commercial])
  @@index([clientId, email])
  @@index([clientId, phone])
  @@index([clientId, nif])
}

enum LeadStatus {
  NOVA                // Lead acabada de entrar
  CONTACTADA          // Primeiro contacto feito
  QUALIFICADA         // Qualificada como oportunidade
  REUNIAO_AGENDADA    // Reuniao marcada
  REUNIAO_EFETUADA    // Reuniao aconteceu
  PROPOSTA_ENVIADA    // Proposta enviada
  NEGOCIACAO          // Em negociacao
  FECHADA_GANHA       // Conversao feita
  FECHADA_PERDIDA     // Perdida
  EM_PAUSA            // Follow-up adiado
}

// ==========================================
// SALES ANALYSIS (per call analysis result)
// ==========================================

model SalesAnalysis {
  id               String     @id @default(cuid())
  clientId         String                        // Cliente a que pertence
  client           Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recordingId      String?    @unique            // Link para Recording (se originou de uma gravacao)
  recording        Recording? @relation(fields: [recordingId], references: [id])
  // Identification
  commercial       String                        // Nome do comercial analisado
  leadName         String?                       // Nome da lead/cliente potencial
  callType         String                        // Discovery, Ads Funnel, Cold Call, Inbound, etc.
  callDate         DateTime
  durationMinutes  Int?
  // Visibility
  visibility       SalesAnalysisVisibility @default(COMMERCIAL_ONLY)
  // Classification
  classification   String                        // "Bom", "Medio", "Mau" ou score tipo texto
  overallScore     Float?                        // Score 0-100 agregado
  // 8 scoring dimensions (0-5 each, from the analysis sheet)
  clarezaFluidez           Int?                  // Clareza e Fluidez do discurso
  tomVoz                   Int?                  // Tom de Voz
  expositivoConversacional String?               // "Expositivo" ou "Conversacional"
  assertividadeControlo    Int?                  // Assertividade e Controlo
  empatia                  Int?                  // Empatia e Bom Ouvinte
  passagemValor            Int?                  // Passagem do valor do servico/produto
  respostaObjecoes         Int?                  // Capacidade de resposta a objecoes
  estruturaMeet            Int?                  // Estrutura da reuniao/chamada
  // Qualitative feedback
  strengths        String?    @db.Text           // Pontos fortes
  weaknesses       String?    @db.Text           // Pontos fracos
  generalTips      String?    @db.Text           // Dicas gerais
  focusNext        String?    @db.Text           // Foco para proximas chamadas
  summary          String?    @db.Text
  // Presented to the commercial? (checkbox similar a "Apresentado em Reuniao")
  presentedToCommercialAt DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([clientId, commercial])
  @@index([clientId, callDate])
}

enum SalesAnalysisVisibility {
  COMMERCIAL_ONLY    // Apenas o comercial e a gerencia
  WHOLE_TEAM         // Toda a equipa comercial do cliente
}

// Weekly call submission tracking with deadlines
model CallSubmission {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  recordingId   String
  recording     Recording @relation(fields: [recordingId], references: [id])
  weekStart     DateTime                    // Monday of the submission week
  submittedAt   DateTime  @default(now())
}

// Delayed feedback with review before publishing
model Feedback {
  id            String         @id @default(cuid())
  sessionId     String?
  session       Session?       @relation(fields: [sessionId], references: [id])
  recordingId   String?
  recording     Recording?     @relation(fields: [recordingId], references: [id])
  userId        String                      // Who receives the feedback
  user          User           @relation(fields: [userId], references: [id])
  content       String         @db.Text      // AI-generated feedback
  personalizedScript String?   @db.Text      // Script adapted to this person's personality
  aiScore       Int?
  status        FeedbackStatus @default(PENDING_REVIEW)
  scheduledFor  DateTime                    // When to make visible (delay)
  reviewedAt    DateTime?                   // When admin reviewed
  reviewedById  String?                     // Who reviewed
  publishedAt   DateTime?                   // When it became visible
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// Meeting reminder
model Reminder {
  id          String   @id @default(cuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id])
  remindAt    DateTime                    // When to send reminder
  sent        Boolean  @default(false)
  type        String   @default("30min")  // 30min, 1hour, 1day
  createdAt   DateTime @default(now())
}

// ==========================================
// TIMELINES (per client, Canva-style phases)
// ==========================================

model Timeline {
  id          String          @id @default(cuid())
  clientId    String
  client      Client          @relation(fields: [clientId], references: [id])
  title       String                        // Ex: "Timeline BeloCredito"
  phases      TimelinePhase[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model TimelinePhase {
  id          String          @id @default(cuid())
  timelineId  String
  timeline    Timeline        @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  number      Int                           // Fase 1, 2, 3, 4
  title       String                        // Ex: "Analise estrategica + gestao comercial"
  startDate   DateTime?
  endDate     DateTime?
  modules     TimelineModule[]
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
}

model TimelineModule {
  id              String          @id @default(cuid())
  phaseId         String
  phase           TimelinePhase   @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  title           String                    // Ex: "Consultoria comercial"
  consultantName  String?                   // Ex: "David Goncalves"
  consultantRole  String?                   // Ex: "Consultor Vendas"
  sessions        TimelineSession[]
  order           Int             @default(0)
  createdAt       DateTime        @default(now())
}

model TimelineSession {
  id          String          @id @default(cuid())
  moduleId    String
  module      TimelineModule  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  number      Int                           // Sessao 1, 2, 3...
  subtitle    String?                       // Ex: "Consultoria estrategica"
  description String?                       // Ex: "Equipa comercial"
  topics      String[]                      // Bullet points
  linkedSessionId String?                   // Link to actual Session
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
}

// ==========================================
// REFERENCES (referral tracking per client)
// ==========================================

model Referral {
  id              String    @id @default(cuid())
  referrerClientId String                   // Client who referred
  referrerClient  Client    @relation("ReferrerClient", fields: [referrerClientId], references: [id])
  referredName    String                    // Name of referred person/company
  referredEmail   String?
  referredPhone   String?
  status          ReferralStatus @default(PENDING)
  convertedToClientId String?               // If converted, link to new client
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum ReferralStatus {
  PENDING           // Referral received, not yet contacted
  CONTACTED         // Initial contact made
  MEETING_SCHEDULED // Meeting booked
  PROPOSAL_SENT     // Proposal sent
  CONVERTED         // Became a client
  LOST              // Didn't convert
}

// Action plan with review workflow
model ActionPlanDraft {
  id          String            @id @default(cuid())
  sessionId   String
  session     Session           @relation(fields: [sessionId], references: [id])
  content     Json                          // The generated action plan
  message     String?           @db.Text    // Formatted message to send
  status      ActionPlanStatus  @default(DRAFT)
  reviewedAt  DateTime?
  sentAt      DateTime?
  sentTo      String?                       // Channel/email where it was sent
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum FeedbackStatus {
  PENDING_REVIEW    // AI generated, waiting admin review
  REVIEWED          // Admin reviewed and approved
  PUBLISHED         // Visible to the user
  REJECTED          // Admin rejected, won't publish
}

enum ActionPlanStatus {
  DRAFT             // Generated, waiting review
  APPROVED          // Reviewed and ready to send
  SENT              // Sent to client
  REJECTED          // Rejected, won't send
}

enum UserRole {
  ADMIN
  CONSULTANT
  MANAGER
  GUEST_CLIENT        // Cliente - so ve o canal de comunicacao
  GUEST_TEAM_MEMBER   // Membro da equipa do cliente - so ve o canal
}

enum ClientStatus {
  FECHADO
  COBRADO
  PRE_ARRANQUE
  LEVANTAMENTO
  APRESENTACAO_TIMELINE
  ATIVO
  INATIVO
  PROJETO_FINALIZADO
}

enum SessionStatus {
  POR_AGENDAR
  MARCADA
  AGUARDAR_CONFIRMACAO
  REAGENDADA
  FALTOU
  CANCELADA
  CONCLUIDA
}

enum Risk {
  BAIXO
  MEDIO
  ALTO
}

enum RecordingType {
  CALL
  MEETING
}

// ==========================================
// COMMERCIAL DASHBOARDS (per client, per market)
// ==========================================

// Dashboard assigned to a client
model ClientDashboard {
  id          String        @id @default(cuid())
  clientId    String        @unique
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  market      MarketType                    // CREDITO, SEGUROS, IMOBILIARIO
  objectives  Json?                         // {chamadas: 1200, agendamentos: 100, ...}
  commercials String[]                      // Names of commercial team members
  records     DashboardRecord[]
  guestUsers  User[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Daily record (End of Day form submission)
model DashboardRecord {
  id              String          @id @default(cuid())
  dashboardId     String
  dashboard       ClientDashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  date            DateTime
  week            Int                         // Week number
  month           String                      // Month name
  trimester       String                      // Q1, Q2, Q3, Q4
  year            Int
  commercial      String                      // Name of the commercial
  channel         String          @default("Cold Calling") // Cold Calling, LinkedIn, Anuncios, Referências
  // Common metrics (all markets)
  callsMade       Int             @default(0)
  callsAnswered   Int             @default(0)
  callsNotAnswered Int            @default(0)
  conversions     Int             @default(0)  // legacy: mantido para compat. Usar conversoesFeitas
  conversoesFeitas Int            @default(0)  // Quantos fecharam contrato (novo campo claro)
  reunioesEfetuadas Int           @default(0)  // Reunioes que realmente aconteceram (substitui agendamentos)
  // Pipeline credito: etapa entre reuniao e fecho (documentacao)
  documentacoesPedidas     Int    @default(0)  // Nº documentacoes pedidas apos reuniao
  documentacoesRecolhidas  Int    @default(0)  // Nº documentacoes efectivamente recolhidas
  documentacoesCompletas   Int    @default(0)  // Nº documentacoes totalmente completas (prontas para banco)
  // Lead qualification (SALs / SQLs) - em todos os canais excepto cold calls
  sals                     Int    @default(0)  // Sales Accepted Leads (viaveis em 1o contacto)
  sqls                     Int    @default(0)  // Sales Qualified Leads (aprovadas pelo banco, prontas a avancar)
  // Novos campos credito: leads totais e acordos verbais
  leads                    Int    @default(0)  // Total de leads geradas (topo do funil)
  acordosVerbais           Int    @default(0)  // Nº acordos verbais (pre-escritura)
  // Duracao media do ciclo de vendas (em dias, preenchida manualmente pelo admin)
  diasSalDocs              Float?              // Tempo medio SAL -> Docs Completas
  diasDocsSql              Float?              // Tempo medio Docs Completas -> SQL
  diasSqlEscritura         Float?              // Tempo medio SQL -> Escritura
  conversionRate  Float?
  // Credito vertentes
  escrituras         Int?
  creditoHabitacaoN  Int?              // Nº creditos habitacao
  creditoHabitacaoV  Float?            // Valor credito habitacao
  creditoPessoalN    Int?              // Nº creditos pessoal
  creditoPessoalV    Float?            // Valor credito pessoal
  creditoConsumoN    Int?              // Nº creditos consumo
  creditoConsumoV    Float?            // Valor credito consumo
  creditoTransferenciaN Int?           // Nº transferencias de credito
  creditoTransferenciaV Float?         // Valor transferencias de credito
  cartoesN           Int?              // Nº cartoes credito
  cartoesV           Float?            // Valor cartoes
  segurosCrossN      Int?              // Nº seguros (cross-sell)
  segurosCrossV      Float?            // Valor seguros
  // Seguros vertentes
  segurosVidaN       Int?
  segurosVidaV       Float?
  segurosSaudeN      Int?
  segurosSaudeV      Float?
  segurosAutoN       Int?
  segurosAutoV       Float?
  segurosHabitacaoN  Int?
  segurosHabitacaoV  Float?
  segurosMultiN      Int?              // Multirriscos
  segurosMultiV      Float?
  segurosOutrosN     Int?
  segurosOutrosV     Float?
  angariacoes        Int?
  premiosTotal       Float?
  apolicesTotal      Int?
  // Imobiliario vertentes
  decisionMakers     Int?
  decisionMakersQualified Int?
  imoAngariacaoN     Int?              // Angariacao
  imoAngariacaoV     Float?
  imoVendaN          Int?              // Venda
  imoVendaV          Float?
  imoArrendamentoN   Int?              // Arrendamento
  imoArrendamentoV   Float?
  imoComercialN      Int?              // Comercial
  imoComercialV      Float?
  // Pipeline (all markets)
  agendamentos    Int?
  reunioes        Int?
  comparecimentos Int?
  showUpRate      Float?
  // Extra
  notes           String?
  createdAt       DateTime        @default(now())
}

enum MarketType {
  CREDITO
  SEGUROS
  IMOBILIARIO
}

// ==========================================
// MESSAGING PLATFORM (BoomLab - Slack-like)
// ==========================================

// Top-level workspace channel (one per client, plus internal team channels)
model Channel {
  id          String        @id @default(cuid())
  name        String
  description String?
  type        ChannelType   @default(CLIENT)
  icon        String?                       // Emoji or image URL
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id])
  createdById String
  createdBy   User          @relation("ChannelCreator", fields: [createdById], references: [id])
  members     ChannelMember[]
  subChannels SubChannel[]
  messages    Message[]
  scheduledMessages ScheduledMessage[]
  guestUsers  User[]        @relation("GuestChannel")
  isArchived  Boolean       @default(false)
  isPrivate   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Accountability Tracker - tarefas diarias registadas pelo utilizador
// Separado dos registos do dashboard (esses sao agregados de metricas). Este e um
// gestor de tarefas pessoais estilo mini-CRM.
model TrackerTask {
  id          String    @id @default(cuid())
  userId      String                              // Dono da tarefa
  user        User      @relation("TrackerTaskOwner", fields: [userId], references: [id], onDelete: Cascade)
  clientId    String?                             // Ligacao opcional a cliente/workspace
  title       String
  description String?   @db.Text
  category    String    @default("OUTROS")        // PROSPECAO | FOLLOW_UP | REUNIAO | ADMIN | OUTROS
  priority    String    @default("MEDIA")         // BAIXA | MEDIA | ALTA | URGENTE
  status      String    @default("POR_FAZER")     // POR_FAZER | EM_CURSO | FEITO | CANCELADO
  deadline    DateTime?
  completedAt DateTime?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, status, deadline])
}

// Mensagens programadas (enviadas num momento futuro; opcionalmente recorrentes)
// Templates de contrato (DOCX). Indexado por (offer, paymentMode, outorgantes).
// Um cliente pode ter 4 variantes por oferta:
//   (Consultoria, PRESTACOES, 1), (Consultoria, PRESTACOES, 2),
//   (Consultoria, AVISTA, 1),     (Consultoria, AVISTA, 2)
// Ficheiro fisico em disco (TEMPLATES_DIR), metadata aqui.
model ContractTemplate {
  id          String   @id @default(cuid())
  offer       String                         // "Consultoria" | "IA" | "Mentoria" | "BoomClub"
  paymentMode String                         // "PRESTACOES" | "AVISTA"
  outorgantes Int                            // 1 ou 2
  filename    String                         // ex: template-consultoria-prestacoes-1out.docx
  displayName String?                        // Nome amigavel
  variables   String[]                       // Lista de {placeholders} detectados no template
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([offer, paymentMode, outorgantes])
}

// Mapeia pipelines do GoHighLevel para ofertas BoomLab
// Usado pelo webhook /api/webhooks/ghl para saber que tipo de cliente criar
model GhlPipelineMapping {
  id              String   @id @default(cuid())
  ghlPipelineId   String   @unique             // Pipeline ID no GHL
  ghlPipelineName String                       // Nome legivel para debug
  offer           String                       // "Consultoria" | "IA" | "Mentoria" | "BoomClub"
  defaultPillars  String[]                     // Pilares a atribuir ao cliente criado
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Regista cada evento recebido do GHL para idempotencia + auditoria
// Nao voltamos a processar eventos ja processados (em caso de retry do GHL)
model GhlEvent {
  id            String   @id @default(cuid())
  ghlEventId    String?  @unique               // Event ID do webhook (quando GHL fornece)
  ghlDealId     String                         // Opportunity / Deal ID
  ghlContactId  String?                        // Contact ID (cliente no GHL)
  ghlPipelineId String?
  ghlStageId    String?
  stageName     String?
  status        String                         // "processed" | "pending" | "failed" | "skipped"
  error         String?                        // Mensagem de erro se status=failed
  payload       Json                           // Payload completo para debug
  createdClientId String?                      // ID do Client BoomLab criado
  createdUserId   String?                      // ID do User criado
  createdChannelId String?                     // ID do Channel criado
  createdAt     DateTime @default(now())
  processedAt   DateTime?

  @@index([ghlDealId])
  @@index([status, createdAt])
}

model ScheduledMessage {
  id                   String    @id @default(cuid())
  channelId            String
  channel              Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  subChannelId         String?
  authorId             String
  author               User      @relation("ScheduledMessageAuthor", fields: [authorId], references: [id])
  content              String    @db.Text
  attachments          Json?
  scheduledFor         DateTime                    // Proximo envio
  recurrence           String?                     // null | "daily" | "weekly" | "monthly"
  recurrenceDayOfWeek  Int?                        // 0-6 para weekly (0 = Domingo)
  recurrenceDayOfMonth Int?                        // 1-31 para monthly
  recurrenceTime       String?                     // "HH:MM" hora de envio
  isActive             Boolean   @default(true)
  lastSentAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([scheduledFor, isActive])
}

// Sub-channels within a channel (like Slack sections/sub-channels)
model SubChannel {
  id          String        @id @default(cuid())
  name        String
  description String?
  channelId   String
  channel     Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User          @relation("SubChannelCreator", fields: [createdById], references: [id])
  members     SubChannelMember[]
  messages    Message[]
  isPrivate   Boolean       @default(false) // Restrict within the channel
  isArchived  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Member of a top-level channel with permissions
model ChannelMember {
  id          String            @id @default(cuid())
  channelId   String
  channel     Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  role        ChannelRole       @default(MEMBER)
  permissions ChannelPermission[]
  lastReadAt  DateTime          @default(now())
  mutedUntil  DateTime?                     // Mute notifications
  createdAt   DateTime          @default(now())

  @@unique([channelId, userId])
}

// Member access to a specific sub-channel
model SubChannelMember {
  id            String      @id @default(cuid())
  subChannelId  String
  subChannel    SubChannel  @relation(fields: [subChannelId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  role          ChannelRole @default(MEMBER)
  lastReadAt    DateTime    @default(now())
  createdAt     DateTime    @default(now())

  @@unique([subChannelId, userId])
}

// Granular permissions per channel member
model ChannelPermission {
  id              String        @id @default(cuid())
  channelMemberId String
  channelMember   ChannelMember @relation(fields: [channelMemberId], references: [id], onDelete: Cascade)
  permission      Permission
  granted         Boolean       @default(true)
  createdAt       DateTime      @default(now())

  @@unique([channelMemberId, permission])
}

model Message {
  id            String      @id @default(cuid())
  content       String      @db.Text
  channelId     String?
  channel       Channel?    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  subChannelId  String?
  subChannel    SubChannel? @relation(fields: [subChannelId], references: [id], onDelete: Cascade)
  authorId      String
  author        User        @relation(fields: [authorId], references: [id])
  parentId      String?                     // Thread reply
  parent        Message?    @relation("ThreadReplies", fields: [parentId], references: [id])
  replies       Message[]   @relation("ThreadReplies")
  isPinned      Boolean     @default(false)
  isSystem      Boolean     @default(false) // Auto-generated (action plans, alerts)
  metadata      Json?                       // Extra data (action plan, file, etc.)
  attachments   Json?                       // File attachments [{name, url, size, type}]
  editedAt      DateTime?
  createdAt     DateTime    @default(now())
}

enum ChannelType {
  CLIENT      // Channel linked to a client (restricted)
  TEAM        // Internal team channel
  GENERAL     // General/announcements
  DIRECT      // Direct message between 2 users
}

enum ChannelRole {
  OWNER       // Full control: delete channel, manage all permissions
  ADMIN       // Can invite/remove members, manage sub-channels
  MEMBER      // Can read and write messages
  GUEST       // Read-only access (for external client users)
}

enum Permission {
  SEND_MESSAGES         // Can send messages
  DELETE_MESSAGES        // Can delete own messages
  DELETE_ANY_MESSAGE     // Can delete any message (moderation)
  PIN_MESSAGES           // Can pin/unpin messages
  INVITE_MEMBERS         // Can add new members to the channel
  REMOVE_MEMBERS         // Can remove members
  MANAGE_SUB_CHANNELS    // Can create/edit/delete sub-channels
  MANAGE_PERMISSIONS     // Can change other members' permissions
  UPLOAD_FILES           // Can upload files/attachments
  VIEW_HISTORY           // Can see message history before joining
}
